---
import { getCollection, render } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import Photo from '@/components/Photo.astro';
import BeforeAfterSlider from '@/components/BeforeAfterSlider.astro';
import ImageCarousel from '@/components/ImageCarousel.astro';
import CostSummary from '@/components/CostSummary.astro';
import ProgressTimeline from '@/components/ProgressTimeline.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: {
      category: project.data.category.toLowerCase(),
      slug: project.id,
    },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const category = project.data.category.toLowerCase();

const hasBeforeAfter = project.data.beforeImage && project.data.afterImage;
const hasDetails = project.data.date || project.data.material || project.data.dimensions || project.data.finish;

// Glob all project images at build time for directory-based progress steps
const allProjectImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/projects/**/*.{jpg,jpeg,png,webp}',
  { eager: true }
);

// Resolve progress steps: use explicit `images` if provided, otherwise
// discover images from `imagesDir` by filtering the glob results
const resolvedProgress = project.data.progress?.map((step) => {
  if (step.images && step.images.length > 0) {
    return { ...step, images: step.images };
  }

  if (step.imagesDir) {
    const dirPrefix = `/src/assets/projects/${project.id}/${step.imagesDir}/`;
    const images = Object.entries(allProjectImages)
      .filter(([path]) => path.startsWith(dirPrefix))
      .sort(([a], [b]) => a.localeCompare(b))
      .map(([, mod]) => mod.default);
    return { ...step, images };
  }

  return { ...step, images: [] as ImageMetadata[] };
});
---

<Layout title={`${project.data.title} — Cardo Tisler`}>
  <article class="pt-32 pb-24">
    <div class="px-8 lg:px-12 mb-12 pb-12">
      <div class="max-w-6xl mx-auto">
        <a
          href={`/${category}`}
          class="inline-flex items-center gap-3 text-smoke hover:text-copper transition-colors duration-300 mb-10 pt-4 group"
        >
          <span class="w-6 h-0.5 bg-copper group-hover:w-10 transition-all duration-300"></span>
          <span class="text-sm tracking-wide">Back</span>
        </a>

        <div class="hammered-border p-5 sm:p-8 bg-charwood">
          <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
            <div>
              <div class="flex items-center gap-3 mb-4">
                <div class="forge-mark"></div>
                <span class="workshop-label">{project.data.category}</span>
              </div>

              <h1 class="font-display text-3xl sm:text-5xl text-bone tracking-wider">
                {project.data.title}
              </h1>

              {project.data.date && (
                <p class="mt-4 text-smoke">
                  {project.data.date.toLocaleDateString('en-GB', {
                    day: '2-digit',
                    month: '2-digit',
                    year: 'numeric',
                  })}
                </p>
              )}
            </div>

            <div class="flex items-center gap-3">
              <div class="rivet"></div>
              <div class="rivet"></div>
              <div class="rivet"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Before/After Slider or Main image -->
    <div class="px-8 lg:px-12 mb-16">
      <div class="max-w-6xl mx-auto">
        {hasBeforeAfter ? (
          <BeforeAfterSlider
            beforeImage={project.data.beforeImage!}
            afterImage={project.data.afterImage!}
            title={project.data.title}
          />
        ) : (
          <div class="timber-card p-4 bg-charwood aspect-[16/10]">
            <Photo
              src={project.data.thumbnail}
              alt={project.data.title}
              widths={[1400, 2000, 2800]}
              class="block max-w-full max-h-full w-auto h-auto"
            />
          </div>
        )}
      </div>
    </div>

    <div class="px-8 lg:px-12">
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-12 gap-12">
          <div class="lg:col-span-7">
            <div class="prose prose-lg max-w-none prose-invert
              prose-p:text-ash prose-p:leading-relaxed
              prose-headings:font-display prose-headings:text-bone prose-headings:font-normal prose-headings:tracking-wide
              prose-a:text-copper prose-a:no-underline hover:prose-a:underline
              prose-strong:text-bone prose-strong:font-medium">
              <Content />
            </div>

            {project.data.images && project.data.images.length > 0 && (
              <div class="mt-6">
                <ImageCarousel
                  images={project.data.images}
                  title={project.data.title}
                />
              </div>
            )}
          </div>

          <!-- Sidebar -->
          <aside class="lg:col-span-4 lg:col-start-9">
            <div class="sticky top-32">
              <!-- Details -->
              {hasDetails && (
                <div class="hammered-border p-6 bg-timber/50">
                  <div class="flex items-center gap-3 mb-6">
                    <div class="rivet"></div>
                    <span class="workshop-label">Details</span>
                  </div>
                  <dl class="space-y-4">
                    {project.data.date && (
                      <div class=" py-3 border-b border-walnut">
                        <dt class="text-smoke">Date</dt>
                        <dd class="text-bone">
                          {project.data.date.toLocaleDateString('en-GB', { day: '2-digit', month: '2-digit', year: 'numeric' })}
                        </dd>
                      </div>
                    )}
                    {project.data.material && (
                      <div class="py-3 border-b border-walnut">
                        <dt class="text-smoke mb-1">Material</dt>
                        <dd class="text-bone">{project.data.material}</dd>
                      </div>
                    )}
                    {project.data.dimensions && (
                      <div class="py-3 border-b border-walnut">
                        <dt class="text-smoke mb-1">Dimensions (mm)</dt>
                        <dd class="text-bone">{project.data.dimensions}</dd>
                      </div>
                    )}
                    {project.data.finish && (
                      <div class="py-3">
                        <dt class="text-smoke mb-1">Finish</dt>
                        <dd class="text-copper font-medium">{project.data.finish}</dd>
                      </div>
                    )}
                  </dl>
                </div>
              )}

              <!-- Cost Summary -->
              {project.data.costs && project.data.costs.length > 0 && (
                <div class="mt-6">
                  <CostSummary costs={project.data.costs} />
                </div>
              )}
            </div>
          </aside>
        </div>
      </div>
    </div>

    {/* Progress Timeline — full-width, below main grid */}
    {resolvedProgress && resolvedProgress.length > 0 && (
      <div class="px-8 lg:px-12 mt-24">
        <div class="max-w-6xl mx-auto">
          <ProgressTimeline
            steps={resolvedProgress}
            projectTitle={project.data.title}
          />
        </div>
      </div>
    )}
  </article>
</Layout>
