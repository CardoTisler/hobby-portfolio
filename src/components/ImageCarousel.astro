---
import Photo from './Photo.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  images: ImageMetadata[];
  title: string;
}

const { images, title } = Astro.props;
---

<div class="image-carousel">
  <div class="hammered-border bg-timber/50 overflow-hidden">
    <!-- Header -->
    <div class="flex items-center justify-between p-6 pb-4">
      <div class="flex items-center gap-3">
        <div class="rivet"></div>
        <span class="workshop-label">Gallery</span>
      </div>
      <span class="carousel-counter text-smoke text-sm tracking-wider">
        <span data-carousel-current>1</span> / <span>{images.length}</span>
      </span>
    </div>

    <!-- Carousel area -->
    <div class="carousel-viewport">
      {images.map((image, index) => (
        <div
          class:list={['carousel-slide', { 'is-active': index === 0 }]}
          data-carousel-slide={index}
        >
          <Photo
            src={image}
            alt={`${title} — ${index + 1}`}
            widths={[1200, 1800, 2400]}
            class="carousel-image"
            data-carousel-open
            data-index={index}
          />
        </div>
      ))}

      <button class="carousel-nav carousel-prev" data-carousel-prev aria-label="Previous image">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <button class="carousel-nav carousel-next" data-carousel-next aria-label="Next image">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  </div>

  <!-- Lightbox -->
  <div class="lightbox" data-lightbox hidden>
    <div class="lightbox-backdrop" data-lightbox-close></div>

    <button class="lightbox-close" data-lightbox-close aria-label="Close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <button class="lightbox-nav lightbox-prev" data-lightbox-prev aria-label="Previous">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <button class="lightbox-nav lightbox-next" data-lightbox-next aria-label="Next">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>

    <div class="lightbox-content">
      {images.map((image, index) => (
        <div class="lightbox-slide" data-slide={index}>
          <Photo
            src={image}
            alt={`${title} — ${index + 1}`}
            widths={[1600, 2400, 3200]}
            class="lightbox-image"
          />
        </div>
      ))}
    </div>

    <div class="lightbox-counter">
      <span data-lightbox-current>1</span> / <span>{images.length}</span>
    </div>
  </div>
</div>

<style>
  /* Carousel viewport */
  .carousel-viewport {
    position: relative;
    background: var(--color-charwood);
    aspect-ratio: 16 / 10;
  }

  /* Carousel slides */
  .carousel-slide {
    display: none;
  }

  .carousel-slide.is-active {
    display: block;
    position: absolute;
    inset: 0;
    animation: fadeIn 0.3s ease-out;
  }

  .carousel-image {
    display: block;
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    cursor: pointer;
  }

  /* Carousel nav buttons */
  .carousel-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-timber);
    border: 1px solid var(--color-walnut);
    color: var(--color-bone);
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: 0.85;
  }

  .carousel-nav:hover {
    background: var(--color-copper);
    border-color: var(--color-copper);
    color: var(--color-charwood);
    opacity: 1;
  }

  .carousel-prev {
    left: 12px;
  }

  .carousel-next {
    right: 12px;
  }

  /* Lightbox styles */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox[hidden] {
    display: none;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(31, 25, 20, 0.95);
    backdrop-filter: blur(8px);
  }

  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 20px;
    z-index: 10;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-timber);
    border: 1px solid var(--color-walnut);
    color: var(--color-bone);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .lightbox-close:hover {
    background: var(--color-copper);
    border-color: var(--color-copper);
    color: var(--color-charwood);
  }

  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-timber);
    border: 1px solid var(--color-walnut);
    color: var(--color-bone);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .lightbox-prev {
    left: 20px;
  }

  .lightbox-next {
    right: 20px;
  }

  .lightbox-nav:hover {
    background: var(--color-copper);
    border-color: var(--color-copper);
    color: var(--color-charwood);
  }

  .lightbox-content {
    position: relative;
    width: 100%;
    max-width: calc(100vw - 180px);
    max-height: calc(100vh - 120px);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-slide {
    display: none;
    width: 100%;
    height: 100%;
  }

  .lightbox-slide.is-active {
    display: flex;
    align-items: center;
    justify-content: center;
    animation: fadeIn 0.3s ease-out;
  }

  .lightbox-image {
    max-width: 100%;
    max-height: calc(100vh - 120px);
    width: auto;
    height: auto;
    object-fit: contain;
    border: 1px solid var(--color-walnut);
  }

  .lightbox-counter {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    padding: 8px 20px;
    background: var(--color-timber);
    border: 1px solid var(--color-walnut);
    font-size: 13px;
    color: var(--color-bone);
    letter-spacing: 0.1em;
  }

  @media (max-width: 768px) {
    .lightbox-nav {
      width: 44px;
      height: 44px;
    }

    .lightbox-prev {
      left: 10px;
    }

    .lightbox-next {
      right: 10px;
    }

    .lightbox-content {
      max-width: calc(100vw - 100px);
    }
  }
</style>

<script>
  document.querySelectorAll('.image-carousel').forEach((carousel) => {
    // --- Carousel state ---
    const carouselSlides = carousel.querySelectorAll('[data-carousel-slide]');
    const carouselCounter = carousel.querySelector('[data-carousel-current]');
    const carouselPrev = carousel.querySelector('[data-carousel-prev]');
    const carouselNext = carousel.querySelector('[data-carousel-next]');
    const carouselImages = carousel.querySelectorAll('[data-carousel-open]');
    const total = carouselSlides.length;
    let carouselIndex = 0;

    const showCarouselSlide = (index: number) => {
      carouselIndex = ((index % total) + total) % total;
      carouselSlides.forEach((slide, i) => {
        slide.classList.toggle('is-active', i === carouselIndex);
      });
      if (carouselCounter) carouselCounter.textContent = String(carouselIndex + 1);
    };

    carouselPrev?.addEventListener('click', () => showCarouselSlide(carouselIndex - 1));
    carouselNext?.addEventListener('click', () => showCarouselSlide(carouselIndex + 1));

    // --- Lightbox state ---
    const lightbox = carousel.querySelector('[data-lightbox]') as HTMLElement;
    const lightboxSlides = carousel.querySelectorAll('[data-slide]');
    const lightboxCounter = lightbox?.querySelector('[data-lightbox-current]');
    const closeButtons = carousel.querySelectorAll('[data-lightbox-close]');
    const lightboxPrev = carousel.querySelector('[data-lightbox-prev]');
    const lightboxNext = carousel.querySelector('[data-lightbox-next]');
    let lightboxIndex = 0;

    const showLightboxSlide = (index: number) => {
      lightboxIndex = ((index % total) + total) % total;
      lightboxSlides.forEach((slide, i) => {
        slide.classList.toggle('is-active', i === lightboxIndex);
      });
      if (lightboxCounter) lightboxCounter.textContent = String(lightboxIndex + 1);
    };

    const openLightbox = (index: number) => {
      showLightboxSlide(index);
      lightbox.hidden = false;
      document.body.style.overflow = 'hidden';
    };

    const closeLightbox = () => {
      lightbox.hidden = true;
      document.body.style.overflow = '';
    };

    // Click image to open lightbox at that index
    carouselImages.forEach((img) => {
      img.addEventListener('click', () => {
        const index = parseInt(img.getAttribute('data-index') || '0');
        openLightbox(index);
      });
    });

    closeButtons.forEach((btn) => {
      btn.addEventListener('click', closeLightbox);
    });

    lightboxPrev?.addEventListener('click', () => showLightboxSlide(lightboxIndex - 1));
    lightboxNext?.addEventListener('click', () => showLightboxSlide(lightboxIndex + 1));

    // --- Keyboard navigation (lightbox only) ---
    document.addEventListener('keydown', (e) => {
      if (lightbox.hidden) return;

      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') showLightboxSlide(lightboxIndex - 1);
      if (e.key === 'ArrowRight') showLightboxSlide(lightboxIndex + 1);
    });
  });
</script>
