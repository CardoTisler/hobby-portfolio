---
import Photo from './Photo.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  id: string;
  images: ImageMetadata[];
  title: string;
}

const { id, images, title } = Astro.props;
---

<div class="lightbox" data-lightbox={id} hidden>
  <div class="lightbox-backdrop" data-lightbox-close></div>

  <button class="lightbox-close" data-lightbox-close aria-label="Close">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>

  {images.length > 1 && (
    <>
      <button class="lightbox-nav lightbox-prev" data-lightbox-prev aria-label="Previous">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <button class="lightbox-nav lightbox-next" data-lightbox-next aria-label="Next">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </>
  )}

  <div class="lightbox-content">
    {images.map((image, index) => (
      <div class="lightbox-slide" data-slide={index}>
        <Photo
          src={image}
          alt={`${title} — ${index + 1}`}
          widths={[1600, 2400, 3200]}
          class="lightbox-image"
        />
      </div>
    ))}
  </div>

  {images.length > 1 && (
    <div class="lightbox-counter">
      <span data-lightbox-current>1</span> / <span>{images.length}</span>
    </div>
  )}
</div>

<style>
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox[hidden] {
    display: none;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(31, 25, 20, 0.95);
    backdrop-filter: blur(8px);
  }

  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 20px;
    z-index: 10;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-timber);
    border: 1px solid var(--color-walnut);
    color: var(--color-bone);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .lightbox-close:hover {
    background: var(--color-copper);
    border-color: var(--color-copper);
    color: var(--color-charwood);
  }

  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-timber);
    border: 1px solid var(--color-walnut);
    color: var(--color-bone);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .lightbox-prev {
    left: 20px;
  }

  .lightbox-next {
    right: 20px;
  }

  .lightbox-nav:hover {
    background: var(--color-copper);
    border-color: var(--color-copper);
    color: var(--color-charwood);
  }

  .lightbox-content {
    position: relative;
    width: 100%;
    max-width: calc(100vw - 180px);
    max-height: calc(100vh - 120px);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-slide {
    display: none;
    width: 100%;
    height: 100%;
  }

  .lightbox-slide.is-active {
    display: flex;
    align-items: center;
    justify-content: center;
    animation: fadeIn 0.3s ease-out;
  }

  .lightbox-image {
    max-width: 100%;
    max-height: calc(100vh - 120px);
    width: auto;
    height: auto;
    object-fit: contain;
    border: 1px solid var(--color-walnut);
  }

  .lightbox-counter {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    padding: 8px 20px;
    background: var(--color-timber);
    border: 1px solid var(--color-walnut);
    font-size: 13px;
    color: var(--color-bone);
    letter-spacing: 0.1em;
  }

  @media (max-width: 768px) {
    .lightbox-nav {
      width: 44px;
      height: 44px;
    }

    .lightbox-prev {
      left: 10px;
    }

    .lightbox-next {
      right: 10px;
    }

    .lightbox-content {
      max-width: calc(100vw - 100px);
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-lightbox]').forEach((lightbox) => {
    const id = lightbox.dataset.lightbox!;
    const slides = lightbox.querySelectorAll<HTMLElement>('[data-slide]');
    const counter = lightbox.querySelector<HTMLElement>('[data-lightbox-current]');
    const prevBtn = lightbox.querySelector<HTMLButtonElement>('[data-lightbox-prev]');
    const nextBtn = lightbox.querySelector<HTMLButtonElement>('[data-lightbox-next]');
    const closeBtns = lightbox.querySelectorAll<HTMLElement>('[data-lightbox-close]');
    const openers = document.querySelectorAll<HTMLElement>(`[data-lightbox-open="${id}"]`);
    const total = slides.length;
    let currentIndex = 0;

    const showSlide = (index: number) => {
      currentIndex = ((index % total) + total) % total;
      slides.forEach((slide, i) => {
        slide.classList.toggle('is-active', i === currentIndex);
      });
      if (counter) counter.textContent = String(currentIndex + 1);
    };

    const open = (index: number) => {
      showSlide(index);
      lightbox.hidden = false;
      document.body.style.overflow = 'hidden';
    };

    const close = () => {
      lightbox.hidden = true;
      document.body.style.overflow = '';
    };

    openers.forEach((el) => {
      el.addEventListener('click', () => {
        const idx = parseInt(el.getAttribute('data-index') || '0', 10);
        open(idx);
      });
    });

    closeBtns.forEach((btn) => btn.addEventListener('click', close));
    prevBtn?.addEventListener('click', () => showSlide(currentIndex - 1));
    nextBtn?.addEventListener('click', () => showSlide(currentIndex + 1));

    document.addEventListener('keydown', (e) => {
      if (lightbox.hidden) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') showSlide(currentIndex - 1);
      if (e.key === 'ArrowRight') showSlide(currentIndex + 1);
    });
  });
</script>
