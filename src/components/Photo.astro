---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  width?: number;
  height?: number;
  widths?: number[];
  densities?: number[];
  quality?: number;
  fill?: boolean;
  class?: string;
  [key: string]: any;
}

const {
  densities,
  widths,
  quality = 95,
  fill = false,
  class: imgClass,
  ...rest
} = Astro.props;

const resolvedDensities = widths ? undefined : (densities ?? [1, 2]);
---

<div class:list={['photo-frame', { 'photo-frame--fill': fill }]}>
  <span class="photo-spinner" aria-hidden="true"></span>
  <Image
    {...rest}
    widths={widths}
    densities={resolvedDensities}
    quality={quality}
    class:list={['photo-img', imgClass]}
  />
</div>

<style>
  .photo-frame {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .photo-spinner {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 44px;
    height: 44px;
    margin: -22px 0 0 -22px;
    pointer-events: none;
    z-index: 1;
    border: 3px solid rgba(184, 115, 51, 0.18);
    border-top-color: var(--color-copper);
    border-radius: 50%;
    animation: photo-spin 900ms linear infinite;
    transition: opacity 400ms ease-out;
    filter: drop-shadow(0 0 12px rgba(184, 115, 51, 0.3));
  }

  .photo-frame.is-loaded .photo-spinner {
    opacity: 0;
  }

  .photo-img {
    opacity: 0;
  }

  .photo-frame.is-loaded .photo-img {
    animation: photo-fade-in 400ms ease-out forwards;
  }

  @keyframes photo-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes photo-fade-in {
    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .photo-spinner {
      animation: none;
    }
    .photo-frame.is-loaded .photo-img {
      animation: none;
      opacity: 1;
    }
  }
</style>

<script>
  function markLoaded(frame: Element) {
    frame.classList.add('is-loaded');
  }

  document.querySelectorAll('.photo-frame').forEach((frame) => {
    const img = frame.querySelector('img') as HTMLImageElement | null;
    if (!img) return;

    if (img.complete && img.naturalWidth > 0) {
      markLoaded(frame);
    } else {
      img.addEventListener('load', () => markLoaded(frame), { once: true });
      img.addEventListener('error', () => markLoaded(frame), { once: true });
    }
  });
</script>
