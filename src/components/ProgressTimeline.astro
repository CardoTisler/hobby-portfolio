---
import Photo from './Photo.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  steps: {
    leftTitle: string;
    rightTitle: string;
    description: string;
    images: ImageMetadata[];
  }[];
  projectTitle: string;
}

const { steps, projectTitle } = Astro.props;
---

<section class="progress-timeline">
  <!-- Section Header -->
  <div class="flex items-center gap-3 mb-3">
    <div class="rivet"></div>
    <span class="workshop-label">Build Progress</span>
  </div>
  <div class="copper-line mb-12"></div>

  <!-- Timeline -->
  <div class="timeline">
    <div class="timeline-line" aria-hidden="true"></div>

    {steps.map((step, index) => {
      const stepNumber = index + 1;
      const isEven = index % 2 === 1;
      const hasMultipleImages = step.images.length > 1;
      const delay = Math.min(index * 100, 300);

      return (
        <div
          class="progress-step"
          data-step-index={index}
          style={`transition-delay: ${delay}ms;`}
        >
          {/* Step title row: leftTitle — line — circle — line — rightTitle */}
          <div class="step-header">
            <span class="step-title-left font-display text-xl text-bone tracking-wide">
              {step.leftTitle}
            </span>
            <span class="step-header-line" aria-hidden="true"></span>
            <div class="step-circle" aria-hidden="true">
              <span>{stepNumber}</span>
            </div>
            <span class="step-header-line" aria-hidden="true"></span>
            <span class="step-title-right font-display text-xl text-bone tracking-wide">
              {step.rightTitle}
            </span>
          </div>

          {/* Step content: two columns on desktop, stacked on mobile */}
          <div class:list={['step-content', { 'step-content--reversed': isEven }]}>
            {/* Text column */}
            <div class="step-text">
              {step.description.trim().split(/\n\n+/).map((paragraph) => (
                <p class="text-ash leading-relaxed text-sm mb-3 last:mb-0">
                  {paragraph.replace(/\n/g, ' ').trim()}
                </p>
              ))}
            </div>

            {/* Image column */}
            <div
              class:list={[
                'step-images',
                { 'progress-step-viewer': hasMultipleImages },
              ]}
              data-viewer-total={step.images.length}
            >
              <div class="step-image-viewport">
                {step.images.map((image, imgIndex) => (
                  <div
                    class:list={[
                      'step-slide',
                      { 'is-active': imgIndex === 0 },
                    ]}
                    data-step-slide={imgIndex}
                  >
                    <Photo
                      src={image}
                      alt={`${projectTitle} — ${step.leftTitle} ${step.rightTitle} (${imgIndex + 1})`}
                      width={800}
                      class="step-slide-image"
                    />
                  </div>
                ))}

                {hasMultipleImages && (
                  <>
                    <button
                      class="step-nav step-nav--prev"
                      data-step-prev
                      aria-label="Previous image"
                    >
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="15 18 9 12 15 6"></polyline>
                      </svg>
                    </button>

                    <button
                      class="step-nav step-nav--next"
                      data-step-next
                      aria-label="Next image"
                    >
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="9 18 15 12 9 6"></polyline>
                      </svg>
                    </button>
                  </>
                )}
              </div>

              {hasMultipleImages && (
                <p class="step-counter text-smoke text-xs text-center mt-2 tracking-wider">
                  <span data-step-current>1</span> / <span>{step.images.length}</span>
                </p>
              )}
            </div>
          </div>
        </div>
      );
    })}
  </div>
</section>

<style>
  /* Timeline container */
  .progress-timeline {
    margin-top: 3rem;
  }

  .timeline {
    position: relative;
    padding-bottom: 2rem;
  }

  /* Vertical copper line — desktop center */
  .timeline-line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 2px;
    background: linear-gradient(
      180deg,
      var(--color-copper) 0%,
      var(--color-brass) 50%,
      var(--color-copper) 100%
    );
    opacity: 0.5;
    transform: translateX(-50%);
  }

  /* Step block */
  .progress-step {
    position: relative;
    margin-bottom: 3rem;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .progress-step:last-child {
    margin-bottom: 0;
  }

  .progress-step.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Step header with circle + title */
  .step-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
    position: relative;
    z-index: 2;
  }

  /* Numbered circle — stays in flow between the two title halves */
  .step-circle {
    width: 36px;
    height: 36px;
    min-width: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(circle at 35% 35%, var(--color-brass), var(--color-copper));
    border: 2px solid var(--color-brass);
    border-radius: 50%;
    box-shadow: 0 0 12px rgba(184, 115, 51, 0.4);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14px;
    color: var(--color-charwood);
    line-height: 1;
    z-index: 2;
  }

  /* Left title: right-aligned so it sits flush against the circle */
  .step-title-left {
    flex: 1;
    text-align: right;
  }

  /* Right title: left-aligned so it sits flush against the circle */
  .step-title-right {
    flex: 1;
    text-align: left;
  }

  /* Short copper lines between title and circle — hidden on desktop, shown on mobile */
  .step-header-line {
    display: none;
  }

  /* Step content — two-column grid on desktop */
  .step-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  /* Reversed layout: image on left, text on right */
  .step-content--reversed .step-text {
    order: 2;
  }

  .step-content--reversed .step-images {
    order: 1;
  }

  /* Step text */
  .step-text {
    background: rgba(42, 34, 28, 0.5);
    border: 1px solid var(--color-walnut);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.75rem;
  }

  .step-text p {
    margin: 0;
  }

  /* Step images */
  .step-images {
    background: rgba(42, 34, 28, 0.5);
    border: 1px solid var(--color-walnut);
    padding: 1.25rem;
  }

  .step-image-viewport {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--color-charwood);
  }

  /* Slides */
  .step-slide {
    display: none;
    position: absolute;
    inset: 0;
  }

  .step-slide.is-active {
    display: block;
    animation: fadeIn 0.3s ease-out;
  }

  .step-slide-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Step nav arrows (32x32, smaller than carousel) */
  .step-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-timber);
    border: 1px solid var(--color-walnut);
    color: var(--color-bone);
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: 0.85;
  }

  .step-nav:hover {
    background: var(--color-copper);
    border-color: var(--color-copper);
    color: var(--color-charwood);
    opacity: 1;
  }

  .step-nav--prev {
    left: 8px;
  }

  .step-nav--next {
    right: 8px;
  }

  /* Counter */
  .step-counter {
    margin-top: 0.5rem;
  }

  /* ---- Mobile layout (< 768px) ---- */
  @media (max-width: 767px) {
    /* Hide the full-length vertical timeline line on mobile */
    .timeline-line {
      display: none;
    }

    .step-header {
      justify-content: center;
      min-height: 36px;
      gap: 0;
      padding-left: 0;
      flex-wrap: wrap;
    }

    /* Allow titles to wrap on mobile */
    .step-title-left,
    .step-title-right {
      flex: 1;
      min-width: 0;
    }

    /* Show short copper lines between titles and circle */
    .step-header-line {
      display: block;
      width: 20px;
      min-width: 20px;
      height: 2px;
      background: linear-gradient(90deg, var(--color-copper), var(--color-brass));
      opacity: 0.5;
      margin: 0 8px;
    }

    /* Stack content vertically */
    .step-content {
      grid-template-columns: 1fr;
      margin-left: 0;
      max-width: none;
    }

    /* On mobile, always images first, then text — override reversed */
    .step-content .step-images {
      order: 1 !important;
    }

    .step-content .step-text {
      order: 2 !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .progress-step {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .step-slide.is-active {
      animation: none;
    }
  }
</style>

<script>
  // --- IntersectionObserver for scroll-triggered animations ---
  const stepElements = document.querySelectorAll('.progress-step');

  if (stepElements.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2 }
    );

    stepElements.forEach((step) => observer.observe(step));
  }

  // --- Inline step image viewers ---
  document.querySelectorAll('.progress-step-viewer').forEach((viewer) => {
    const slides = viewer.querySelectorAll('[data-step-slide]');
    const counterCurrent = viewer.querySelector('[data-step-current]');
    const prevBtn = viewer.querySelector('[data-step-prev]');
    const nextBtn = viewer.querySelector('[data-step-next]');
    const total = slides.length;
    let currentIndex = 0;

    const showSlide = (index: number) => {
      currentIndex = ((index % total) + total) % total;
      slides.forEach((slide, i) => {
        slide.classList.toggle('is-active', i === currentIndex);
      });
      if (counterCurrent) {
        counterCurrent.textContent = String(currentIndex + 1);
      }
    };

    prevBtn?.addEventListener('click', () => showSlide(currentIndex - 1));
    nextBtn?.addEventListener('click', () => showSlide(currentIndex + 1));
  });
</script>
